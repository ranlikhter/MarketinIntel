# Copy this file to backend/.env and configure your values

# Database Configuration
DATABASE_URL=sqlite:///./data/products.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:3000

# Scraping Configuration
SCRAPE_DELAY_MIN=2
SCRAPE_DELAY_MAX=5
MAX_RETRIES=3

# Amazon Configuration
AMAZON_BASE_URL=https://www.amazon.com

# CORS Configuration (for local development)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Redis / Celery ────────────────────────────────────────────────────────────
# Redis is required for Celery background tasks and the beat scheduler
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Full URL overrides the individual vars above (use this for Redis Cloud / Railway)
# REDIS_URL=redis://:password@host:port/0

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@marketintel.app

# ── Twilio (SMS alerts) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567

# ── Stripe (billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
