[run]
source = .
omit =
    tests/*
    alembic/*
    */__pycache__/*
    */site-packages/*

[report]
show_missing = true
skip_empty = true
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    pass

[html]
directory = htmlcov
title = MarketIntel Coverage Report
